{
  "expo": {
    "name": "Daylo",
    "slug": "daylo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "daylo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daylocoaching.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Daylo needs access to your calendar to export confirmed games.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.daylocoaching.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B2A4A"
        }
      ],
      "expo-calendar",
      "expo-image-picker",
      "expo-document-picker",
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86d70bb2-8a97-419a-b278-d9904fe415d2"
      }
    },
    "owner": "daylo-coaching-app"
  }
}
